<!--
    Splash icon (Android 12+ SplashScreen API) — СВЕТЛАЯ тема.

    AnimatedVectorDrawable: иконка GitHub-mark плавно появляется
    (fillAlpha 0 → 1) и одновременно слегка увеличивается
    (scaleX/scaleY 0.78 → 1.0). Группа `root_group` имеет
    pivotX/pivotY = 144 (центр viewport 288x288), поэтому
    масштабирование идёт ровно из центра, без сноса позиции иконки.

    Тайминги подобраны так, чтобы вписаться в окно
    `windowSplashScreenAnimationDuration` (700ms, см. styles.xml).
    Интерполятор — стандартный Material easing fast_out_slow_in:
    даёт плавный приход к финальному размеру / непрозрачности
    без «дёрганья» в конце.

    Структура vector (animated-vector → набор `<target>` с
    objectAnimator) — стандартный паттерн animated-vector,
    поддерживается с API 21. Для splash-screen drawable именно
    AnimatedVectorDrawable рекомендован Google в
    https://developer.android.com/develop/ui/views/launch/splash-screen
    как способ задать вступительную анимацию иконки.

    Иконка — Iconify mdi:github 156×156dp (24×24 viewport, scale 6.5,
    translate 66,66 → центр 144,144 на viewport 288×288), цвет
    AppColors.accent (#9885E2) — 1:1 как на light onboarding-хиро.

    ВАЖНО: vector ДОЛЖЕН быть непустым. Если drawable пустой/полностью
    прозрачный — Android (особенно HyperOS/MIUI) откатывается на
    @mipmap/ic_launcher и показывает квадратный launcher-icon на сплэше.
    Стартовая fillAlpha=1 в самом vector это гарантирует — анимация
    запускается из 0 только в момент старта splash.
-->
<animated-vector
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">
    <aapt:attr name="android:drawable">
        <vector
            android:width="288dp"
            android:height="288dp"
            android:viewportWidth="288"
            android:viewportHeight="288">
            <group
                android:name="root_group"
                android:pivotX="144"
                android:pivotY="144"
                android:scaleX="1"
                android:scaleY="1">
                <group
                    android:translateX="66"
                    android:translateY="66"
                    android:scaleX="6.5"
                    android:scaleY="6.5">
                    <path
                        android:name="github_path"
                        android:fillColor="#9885E2"
                        android:fillAlpha="1"
                        android:pathData="M12,2 A10,10 0 0,0 2,12 c0,4.42 2.87,8.17 6.84,9.5 c0.5,0.08 0.66,-0.23 0.66,-0.5 v-1.69 c-2.77,0.6 -3.36,-1.34 -3.36,-1.34 c-0.46,-1.16 -1.11,-1.47 -1.11,-1.47 c-0.91,-0.62 0.07,-0.6 0.07,-0.6 c1,0.07 1.53,1.03 1.53,1.03 c0.87,1.52 2.34,1.07 2.91,0.83 c0.09,-0.65 0.35,-1.09 0.63,-1.34 c-2.22,-0.25 -4.55,-1.11 -4.55,-4.92 c0,-1.11 0.38,-2 1.03,-2.71 c-0.1,-0.25 -0.45,-1.29 0.1,-2.64 c0,0 0.84,-0.27 2.75,1.02 c0.79,-0.22 1.65,-0.33 2.5,-0.33 s1.71,0.11 2.5,0.33 c1.91,-1.29 2.75,-1.02 2.75,-1.02 c0.55,1.35 0.2,2.39 0.1,2.64 c0.65,0.71 1.03,1.6 1.03,2.71 c0,3.82 -2.34,4.66 -4.57,4.91 c0.36,0.31 0.69,0.92 0.69,1.85 V21 c0,0.27 0.16,0.59 0.67,0.5 C19.14,20.16 22,16.42 22,12 A10,10 0 0,0 12,2 Z"/>
                </group>
            </group>
        </vector>
    </aapt:attr>

    <!-- Лёгкий scale-up иконки из центра. 0.78 → 1.0 за 700ms даёт
         ощущение «иконка плавно раздувается», не выходя из safe-zone
         192×192dp (на пике scale=1.0 иконка 156dp, всё ещё внутри). -->
    <target android:name="root_group">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="scaleX"
                    android:valueFrom="0.78"
                    android:valueTo="1.0"
                    android:duration="700"
                    android:interpolator="@android:interpolator/fast_out_slow_in"/>
                <objectAnimator
                    android:propertyName="scaleY"
                    android:valueFrom="0.78"
                    android:valueTo="1.0"
                    android:duration="700"
                    android:interpolator="@android:interpolator/fast_out_slow_in"/>
            </set>
        </aapt:attr>
    </target>

    <!-- Fade-in: 0 → 1 чуть быстрее, чем scale, чтобы иконка успела
         «налиться» цветом до того, как закончит подрастать. -->
    <target android:name="github_path">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="fillAlpha"
                android:valueFrom="0.0"
                android:valueTo="1.0"
                android:duration="500"
                android:interpolator="@android:interpolator/fast_out_slow_in"/>
        </aapt:attr>
    </target>
</animated-vector>
