<!--
    AnimatedVectorDrawable для системного сплэш-экрана (Android 12+),
    светлая тема. GitHub-логотип в accent-цвете (#9885E2,
    AppColors.defaultAccent).

    Структура и тайминги 1:1 повторяют Telegram-овский
    `tg_splash_320.xml` (DrKLO/Telegram), с двумя отличиями:
      1. У нас только одна `path`-иконка (у TG — две: фон-круг
         и плашка-самолётик), потому весь bg-target из TG-схемы
         просто отсутствует.
      2. Интерполятор scale-анимации — `linear_out_slow_in`
         (плавное замедление к концу) вместо `overshoot_interpolator`.
         Overshoot даёт визуальную «пружину» / «прыжок и отпружинивание»
         в конце анимации; пользователь несколько раз явно просил
         «без отпружинивания», «нормальная анимация появления».

    Тайминги (всё совпадает с TG):
      • startOffset = 200ms — первые 200ms ОС играет свою встроенную
        enter-анимацию сплэш-окна (круговое раскрытие фона из точки
        тапа). В это время наша иконка ПОЛНОСТЬЮ ПРОЗРАЧНА
        (initial fillAlpha = 0), чтобы не конфликтовать с системным
        fade-in иконки. На некоторых OEM-ROM, если AVD стартует
        одновременно с системным fade-in, две анимации накладываются
        и пользователь видит «мигание»/«дёргание». TG-шный delay
        фиксит это для всех устройств;
      • duration scale = 300ms (0.5 → 1.0) — иконка плавно
        «надувается» до нужного размера, `linear_out_slow_in`
        (быстрый старт, плавное замедление);
      • duration fillAlpha = 100ms (0 → 1) — быстрый fade-in
        в начале scale-анимации, чтобы иконка появилась к моменту
        когда она уже подросла до ~70%;
      • суммарно: 200 + 300 = 500ms (совпадает с
        windowSplashScreenAnimationDuration в styles.xml).

    Визуальный размер иконки внутри viewport'а 320×320 — 140×140
    (примерно как у TG, у них логотип ~110/320). При system splash
    icon size 192dp это даёт визуально 84dp ширину иконки, что
    надёжно укладывается в любые OEM-ные softmask'и
    (Samsung One UI, MIUI, ColorOS режут сплэш-иконку на круг
    разного диаметра — если иконка слишком большая, на этих
    устройствах видны срезанные края, на что пользователь и жаловался
    как на «обрезание во время раскрытия»). Раньше у нас иконка
    занимала 200/320 = 62.5% viewport'а (визуально 120dp), и на
    OEM-launcher'ах это упиралось в softmask.
-->
<animated-vector
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">
    <aapt:attr name="android:drawable">
        <vector
            android:name="splash"
            android:width="320dp"
            android:height="320dp"
            android:viewportWidth="320"
            android:viewportHeight="320">
            <group
                android:name="scaleme"
                android:pivotX="160"
                android:pivotY="160"
                android:scaleX="0.5"
                android:scaleY="0.5">
                <group
                    android:translateX="90"
                    android:translateY="90"
                    android:scaleX="5.833"
                    android:scaleY="5.833">
                    <path
                        android:name="icon"
                        android:fillColor="#9885E2"
                        android:fillAlpha="0"
                        android:pathData="M12,2 A10,10 0 0,0 2,12 c0,4.42 2.87,8.17 6.84,9.5 c0.5,0.08 0.66,-0.23 0.66,-0.5 v-1.69 c-2.77,0.6 -3.36,-1.34 -3.36,-1.34 c-0.46,-1.16 -1.11,-1.47 -1.11,-1.47 c-0.91,-0.62 0.07,-0.6 0.07,-0.6 c1,0.07 1.53,1.03 1.53,1.03 c0.87,1.52 2.34,1.07 2.91,0.83 c0.09,-0.65 0.35,-1.09 0.63,-1.34 c-2.22,-0.25 -4.55,-1.11 -4.55,-4.92 c0,-1.11 0.38,-2 1.03,-2.71 c-0.1,-0.25 -0.45,-1.29 0.1,-2.64 c0,0 0.84,-0.27 2.75,1.02 c0.79,-0.22 1.65,-0.33 2.5,-0.33 s1.71,0.11 2.5,0.33 c1.91,-1.29 2.75,-1.02 2.75,-1.02 c0.55,1.35 0.2,2.39 0.1,2.64 c0.65,0.71 1.03,1.6 1.03,2.71 c0,3.82 -2.34,4.66 -4.57,4.91 c0.36,0.31 0.69,0.92 0.69,1.85 V21 c0,0.27 0.16,0.59 0.67,0.5 C19.14,20.16 22,16.42 22,12 A10,10 0 0,0 12,2 Z"/>
                </group>
            </group>
        </vector>
    </aapt:attr>
    <target android:name="scaleme">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="scaleX"
                    android:startOffset="200"
                    android:duration="300"
                    android:valueFrom="0.5"
                    android:valueTo="1"
                    android:valueType="floatType"
                    android:interpolator="@android:interpolator/linear_out_slow_in"/>
                <objectAnimator
                    android:propertyName="scaleY"
                    android:startOffset="200"
                    android:duration="300"
                    android:valueFrom="0.5"
                    android:valueTo="1"
                    android:valueType="floatType"
                    android:interpolator="@android:interpolator/linear_out_slow_in"/>
            </set>
        </aapt:attr>
    </target>
    <target android:name="icon">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="fillAlpha"
                android:startOffset="200"
                android:duration="100"
                android:valueFrom="0"
                android:valueTo="1"
                android:valueType="floatType"
                android:interpolator="@android:interpolator/fast_out_slow_in"/>
        </aapt:attr>
    </target>
</animated-vector>
